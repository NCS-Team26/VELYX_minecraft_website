      "discord:stock-webhook:once": "node discord-bot/stock-webhook.mjs --once",
      "minecraft:api-bridge": "node server/minecraft-api-bridge.mjs",
      "auth:setup:aws": "node scripts/aws-auth-setup.mjs",
      "deploy:aws": "npm run build && node scripts/aws-deploy.mjs",
      "preview": "vite preview --host 127.0.0.1",
      "modpack:server": "python scripts/minecraft/install-modrinth-pack.py --side server --target .modpack/server-plugins --minecraft-version 26.1.2 --prune-managed",
      "modpack:server:dry": "python scripts/minecraft/install-modrinth-pack.py --side server --target .modpack/server-plugins --minecraft-version 26.1.2 --dry-run",
      "modpack:client:dry": "python scripts/minecraft/install-modrinth-pack.py --side client --target .modpack/client-mods --minecraft-version 26.1.2 --dry-run",
      "modpack:client": "python scripts/minecraft/install-modrinth-pack.py --side client --target .modpack/client-mods --minecraft-version 26.1.2 --prune-managed",
      "modpack:client:mrpack": "npm run modpack:client && python scripts/minecraft/export-modrinth-pack.py",
      "modpack:fabric-server": "python scripts/minecraft/install-modrinth-pack.py --side fabric-server --target .modpack/fabric-server-mods --minecraft-version 26.1.2 --prune-managed",
      "modpack:fabric-server:dry": "python scripts/minecraft/install-modrinth-pack.py --side fabric-server --target .modpack/fabric-server-mods --minecraft-version 26.1.2 --dry-run"
    }
